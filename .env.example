# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_INTAKE_MODEL=claude-haiku-4-5-20251001

# ── LangSmith (observability) ───────────────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=techblogcopilot
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Encryption ──────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BLOG_COPILOT_KEK=your-fernet-key-here

# ── GitHub OAuth App ────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL: http://localhost:8000
# Authorization callback URL: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=...
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/github/callback

# ── Notion OAuth App ────────────────────────────────────────────────────────
# Create at: https://www.notion.so/profile/integrations → New integration (Public)
# Redirect URI: http://localhost:8000/auth/notion/callback
NOTION_CLIENT_ID=...
NOTION_CLIENT_SECRET=secret_...
NOTION_OAUTH_REDIRECT_URI=http://localhost:8000/auth/notion/callback

# ── LinkedIn OAuth App ──────────────────────────────────────────────────────
# Create at: https://www.linkedin.com/developers/apps → New App
# Required products: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn"
# Redirect URL: http://localhost:8000/auth/linkedin/callback (HTTPS required in prod)
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback

# ── Unsplash (optional) ──────────────────────────────────────────────────────
# Get a free key at https://unsplash.com/developers
# When set, the drafting agent can search for relevant images to embed.
UNSPLASH_ACCESS_KEY=

# ── Web search (optional) ────────────────────────────────────────────────────
# Get a free key at https://tavily.com (1,000 searches/month free).
# When set, the drafting agent can look up articles on topics from the repo
# or requested via intake answers. Leave blank to disable web search.
TAVILY_API_KEY=tvly-...

# ── App ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=your-secret-key-here

# Local dev: http://localhost:8000
# Production: set to your Railway/Fly.io API service URL, e.g. https://api-xyz.railway.app
APP_BASE_URL=http://localhost:8000

# Base URL of the Streamlit frontend — used as redirect destination after OAuth completes
# Local dev: http://localhost:8501
# Production: set to your Railway/Fly.io frontend service URL
FRONTEND_URL=http://localhost:8501

# Set to true for human-readable logs; false (default) emits JSON for log collectors
DEBUG=false
